# ============================================================
# PhishGuard — Environment Variables
# Section 8 — core/config.py (Pydantic BaseSettings)
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL async DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://phishguard:password@localhost:5432/phishguard

# ── Cache / Broker ───────────────────────────────────────────
# Redis — used for Celery broker, SSE Pub/Sub, JWT blacklist, rate limits
REDIS_URL=redis://localhost:6379/0

# Celery result backend (same Redis, separate DB index)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Security ─────────────────────────────────────────────────
# JWT signing secret — minimum 32 characters
# Generate: openssl rand -hex 32
JWT_SECRET=

# JWT access token lifetime in hours (default: 8)
JWT_EXPIRE_HOURS=8

# HMAC secret for quarantine digest one-time tokens
# Generate: openssl rand -hex 32
DIGEST_HMAC_SECRET=

# Fernet symmetric key for encrypting IMAP passwords at rest
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FERNET_KEY=

# ── External APIs ────────────────────────────────────────────
# Anthropic Claude API — FR-04 explanation engine + AI assistant
ANTHROPIC_API_KEY=

# Resend transactional email SDK — FR-06 digest delivery
RESEND_API_KEY=

# ── Application ──────────────────────────────────────────────
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Forwarding inbox domain slug prefix
FORWARDING_DOMAIN=phishguard.app

# ML model version tag (matches ml/model.pkl artefact)
MODEL_VERSION=rf_v1.0.0

# Hardcoded realistic phishing .eml for the Load Demo Sample button (UI Figure 8)
# Paste raw .eml content as a single-line string (escape newlines as \n)
DEMO_SAMPLE_EML=

# Volume mount path for generated export CSV files
EXPORT_VOLUME_PATH=/mnt/exports
