# ── Secrets ──────────────────────────────────────────────────
backend/.env
.env
!backend/.env.example

# ── TLS Certificates (never commit private keys) ─────────────
backend/nginx/ssl/

# ── ML Artefacts ─────────────────────────────────────────────
# model.pkl and metrics.json ARE committed (build artefacts).
# Exclude raw training data and intermediate files only.
backend/ml/*.csv
backend/ml/*.joblib

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Testing & Coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Type Checking ────────────────────────────────────────────
.mypy_cache/

# ── Export Volume (Docker bind mount) ────────────────────────
/mnt/exports/

# ── Virtual Environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/
.yarn/
.yarn-cache/

# Build outputs
dist/
build/
.next/
out/
coverage/

# Environment variables and secrets
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Temporary/cache files
.cache/
.tmp/
temp/
*.tmp

# Local database/files
*.sqlite
*.sqlite3
*.db

# Test artifacts
playwright-report/
test-results/
